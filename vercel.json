{
  "version": 2,
  "name": "rpa-academy",
  "buildCommand": "python build.py",
  "outputDirectory": "dist",
  "installCommand": "pip install -r requirements.txt",
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/servicios", "dest": "/servicios.html" },
    { "src": "/sobre-mi", "dest": "/sobre-mi.html" },
    { "src": "/contacto", "dest": "/contacto.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
